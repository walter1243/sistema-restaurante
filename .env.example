# Canonical environment keys for Sistema Restaurante
# Render: backend API and PostgreSQL
# Vercel: only needed if you keep running backend there or inject public values manually

DATABASE_URL=
APP_API_URL=https://sistema-restaurante-api.onrender.com
APP_PUBLIC_URL=https://app.foodos.com.br
DELIVERY_PUBLIC_URL=https://entregador.foodos.com.br
APP_RESTAURANT_SLUG=
APP_GOOGLE_MAPS_API_KEY=

CORS_ALLOWED_ORIGINS=https://foodos.com.br,https://www.foodos.com.br
CORS_ALLOWED_ORIGIN_REGEX=https://(.*\.vercel\.app|([a-z0-9-]+\.)?foodos\.com\.br)$

MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_CLAIMS_SUB=mailto:suporte@restaurante.local

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=1
SMTP_SSL=0

TERMS_URL=
PRIVACY_URL=

SUPER_ADMIN_NOME=
SUPER_ADMIN_LOGIN=
SUPER_ADMIN_SENHA=

DEFAULT_RESTAURANTE_NOME=
DEFAULT_RESTAURANTE_SLUG=
DEFAULT_RESTAURANTE_EMAIL=
DEFAULT_RESTAURANTE_SENHA=
DEFAULT_RESTAURANTE_PLAN_TYPE=standard
