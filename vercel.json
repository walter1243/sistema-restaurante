{
  "version": 2,
  "builds": [
    {
      "src": "**.html",
      "use": "@vercel/static"
    },
    {
      "src": "**.js",
      "use": "@vercel/static"
    },
    {
      "src": "**.css",
      "use": "@vercel/static"
    },
    {
      "src": "**.webmanifest",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api_config.js", "dest": "/api_config.js" },
    { "src": "/health", "dest": "https://sistema-restaurante-f87o.onrender.com/health" },
    { "src": "/openapi.json", "dest": "https://sistema-restaurante-f87o.onrender.com/openapi.json" },
    { "src": "/api/(.*)", "dest": "https://sistema-restaurante-f87o.onrender.com/api/$1" },
    { "src": "/p/([^/?#]+)", "dest": "/index.html?slug=$1&mesa=1" },
    { "src": "/admin/([^/?#]+)", "dest": "/admin.html?slug=$1" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/entregador", "dest": "/entregador.html" },
    { "src": "/super-admin", "dest": "/super_admin.html" },
    { "src": "/site-vendas", "dest": "/site_vendas.html" },
    { "src": "/rastreio-entrega", "dest": "/rastreio_entrega.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
