{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "**.html",
      "use": "@vercel/static"
    },
    {
      "src": "**.js",
      "use": "@vercel/static"
    },
    {
      "src": "**.css",
      "use": "@vercel/static"
    },
    {
      "src": "**.webmanifest",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api_config.js", "dest": "/api_config.js" },
    { "src": "/health", "dest": "main.py" },
    { "src": "/api/(.*)", "dest": "main.py" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/entregador", "dest": "/entregador.html" },
    { "src": "/super-admin", "dest": "/super_admin.html" },
    { "src": "/site-vendas", "dest": "/site_vendas.html" },
    { "src": "/rastreio-entrega", "dest": "/rastreio_entrega.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
